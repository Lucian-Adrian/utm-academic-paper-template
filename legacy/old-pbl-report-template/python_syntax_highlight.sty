\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{python_syntax_highlight}[20/02/2024 Python Code Syntax Highlighting; provided by Gusev Roman]

\RequirePackage{listings}
\RequirePackage{xcolor}
\RequirePackage{color}
\RequirePackage{courier}
\RequirePackage{fontenc}

\renewcommand*{\lstlistlistingname}{Code Listings}
\renewcommand*{\lstlistingname}{Code Listing}

% color def
\definecolor{darkred}{rgb}{0.6,0.0,0.0}
\definecolor{darkgreen}{rgb}{0,0.50,0}
\definecolor{lightblue}{rgb}{0.0,0.42,0.91}
\definecolor{orange}{rgb}{0.99,0.48,0.13}
\definecolor{grass}{rgb}{0.18,0.80,0.18}
\definecolor{pink}{rgb}{0.97,0.15,0.45}
\definecolor{codegreen}{rgb}{0,0.6,0}
\definecolor{codegray}{rgb}{0.5,0.5,0.5}
\definecolor{codepurple}{rgb}{0.58,0,0.82}
\definecolor{backcolour}{rgb}{0.95,0.95,0.92}
\definecolor{codewhite}{rgb}{0.85,0.85,0.85}
\definecolor{strings}{HTML}{5AC067}

% 0. Basic Color Theme
\lstdefinestyle{colored}{ %
  basicstyle=\footnotesize\ttfamily,
  backgroundcolor=\color{white},
  commentstyle=\color{green}\itshape,
  keywordstyle=\color{blue}\bfseries\itshape,
  stringstyle=\color{red},
}
% 1. General Python Keywords List
\lstdefinelanguage{PythonPlus}[]{Python}{
  morekeywords=[1]{,as,assert,nonlocal,with,yield,self,True,False,None,} % Python builtin
  morekeywords=[2]{,__init__,__add__,__mul__,__div__,__sub__,__call__,__getitem__,__setitem__,__eq__,__ne__,__nonzero__,__rmul__,__radd__,__repr__,__str__,__get__,__truediv__,__pow__,__name__,__future__,__all__,}, % magic methods
  morekeywords=[3]{,object,type,isinstance,copy,deepcopy,zip,enumerate,reversed,list,set,len,dict,tuple,range,xrange,append,execfile,real,imag,reduce,str,repr,}, % common functions
  morekeywords=[4]{,Exception,NameError,IndexError,SyntaxError,TypeError,ValueError,OverflowError,ZeroDivisionError,}, % errors
  morekeywords=[5]{,ode,fsolve,sqrt,exp,sin,cos,arctan,arctan2,arccos,pi, array,norm,solve,dot,arange,isscalar,max,sum,flatten,shape,reshape,find,any,all,abs,plot,linspace,legend,quad,polyval,polyfit,hstack,concatenate,vstack,column_stack,empty,zeros,ones,rand,vander,grid,pcolor,eig,eigs,eigvals,svd,qr,tan,det,logspace,roll,min,mean,cumsum,cumprod,diff,vectorize,lstsq,cla,eye,xlabel,ylabel,squeeze,}, % numpy / math
}
% 2. New Language based on Python
\lstdefinelanguage{PyBrIM}[]{PythonPlus}{
  emph={d,E,a,Fc28,Fy,Fu,D,des,supplier,Material,Rectangle,PyElmt},
}
% 3. Extended theme
\lstdefinestyle{colorEX}{
  basicstyle=\ttfamily \color{codewhite}, 
  backgroundcolor=\color{black},
  identifierstyle=\color{codewhite},
  commentstyle=\color{codegray},
  keywordstyle=\color{orange},
  keywordstyle=[2]\color{codepurple},
  keywordstyle=[3]\color{grass},
  keywordstyle=[4]\color{red},
  keywordstyle=[5]\color{orange},
  stringstyle=\color{grass},
  emphstyle=\color{pink}\underbar,
  aboveskip=1em,
  breaklines=true,
  abovecaptionskip=-6pt,
  captionpos=b,
  escapeinside={\%*}{*)},
  frame=single,
  numbers=left,
  numbersep=15pt,
  numberstyle=\tiny,
  showspaces=false,
  showstringspaces=false,
  language=PyBrIM
}

\lstdefinestyle{console}{
  basicstyle=\ttfamily \color{codewhite}, 
  backgroundcolor=\color{black},
  aboveskip=1em,
  breaklines=true,
  abovecaptionskip=-6pt,
  captionpos=b,
  escapeinside={\%*}{*)},
  frame=single,
  numbers=left,
  numbersep=15pt,
  numberstyle=\tiny,
  showspaces=false,
  showstringspaces=false,
  escapeinside={(*}{*)},
}

\lstnewenvironment{python}[2][]{%
	\lst@TestEOLChar{#2}%
	\lstset{style=colorEX}%
	\lstset{#1}%  % has to be in an  extra \lstset{} command so that labels work correctly
	\csname\@lst @SetFirstNumber\endcsname%
}{%
	\let\if@nobreak\iffalse%
	\csname\@lst @SaveFirstNumber\endcsname%
}

\lstnewenvironment{console}[2][]{%
	\lst@TestEOLChar{#2}%
	\lstset{style=console}%
	\lstset{#1}%  % has to be in an  extra \lstset{} command so that labels work correctly
	\csname\@lst @SetFirstNumber\endcsname%
}{%
	\let\if@nobreak\iffalse%
	\csname\@lst @SaveFirstNumber\endcsname%
}